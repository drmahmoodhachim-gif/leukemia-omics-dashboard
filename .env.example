# LeukemiaOmics — environment template (copy to .env.local)

# Supabase — use a NEW project, schema leukemia_omics
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_SCHEMA=leukemia_omics

# Server-only (ingest sync) — from Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Optional: faster GEO/PubMed ingest (NCBI API key)
NCBI_API_KEY=

# Cron protection for /api/cron/ingest
CRON_SECRET=change-me-leukemia-cron

# Optional login (leave unset for open access)
# Generate AUTH_SECRET: openssl rand -hex 32
AUTH_SECRET=
AUTH_USERNAME=
AUTH_PASSWORD=
